{
  "name": "@audrey/mcp-server",
  "version": "0.1.0",
  "private": true,
  "description": "Audrey TCP MCP server — exposes matter, counterparty, client, and position intelligence as MCP tools",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/**/*.ts",
    "onboard": "tsx scripts/onboard.ts",
    "jwt:keygen": "tsx src/oauth/jwt.ts"
  },
  "dependencies": {
    "@fastify/cors": "^9.0.0",
    "@fastify/formbody": "^7.4.0",
    "@modelcontextprotocol/sdk": "^1.0.0",
    "@supabase/supabase-js": "^2.39.0",
    "fastify": "^4.26.0",
    "jose": "^6.2.3",
    "pino": "^9.0.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.56.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.0",
    "vitest": "^1.3.0"
  },
  "engines": {
    "node": ">=22"
  }
}
