# Supabase — shared instance with existing Audrey backend
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ... # service role: required for OAuth server (oauth_clients/codes inserts, user provisioning, magic-link generation). NEVER used in tool handlers.
SUPABASE_ANON_KEY=eyJ...         # used for tool handlers, RLS enforced

# Server
PORT=8080
NODE_ENV=development

# Logging
LOG_LEVEL=info

# Public base URL — used in OAuth metadata responses (issuer, redirects).
# Railway auto-injects RAILWAY_PUBLIC_DOMAIN; this overrides if set.
AUDREY_BASE_URL=https://audrey-tcp-production.up.railway.app

# JWT signing key (PEM, PKCS8). Generate with:
#   openssl genpkey -algorithm RSA -out private.pem -pkeyopt rsa_keygen_bits:2048
#   cat private.pem  # paste the contents (multi-line is fine; \n is also accepted)
# Required in production. Dev generates an ephemeral key with a warning.
AUDREY_JWT_PRIVATE_KEY=

# Signing key for OAuth state cookies (HMAC). Any random string >= 32 chars.
# Generate with: openssl rand -base64 32
# Required in production.
AUDREY_STATE_SECRET=

# Firm identity (legacy / fallback)
# - stdio (Claude Desktop): set AUDREY_FIRM_ID in claude_desktop_config.json's
#   `env` block for the audrey server entry.
# - HTTP: prefer Bearer JWT; AUDREY_FIRM_ID only as a dev override.
AUDREY_FIRM_ID=

# (Reserved for future OIDC integration)
OAUTH_ISSUER_URL=https://app.audrey.xeqtor.com
