# Supabase — shared instance with existing Audrey backend
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ... # service role for migrations only, never used in tool handlers
SUPABASE_ANON_KEY=eyJ...         # used for authenticated requests, RLS enforced

# Server
PORT=8080
NODE_ENV=development

# Logging
LOG_LEVEL=info

# OAuth (when configured)
OAUTH_ISSUER_URL=https://app.audrey.xeqtor.com
