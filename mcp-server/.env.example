# Supabase — shared instance with existing Audrey backend
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ... # service role for migrations only, never used in tool handlers
SUPABASE_ANON_KEY=eyJ...         # used for authenticated requests, RLS enforced

# Server
PORT=8080
NODE_ENV=development

# Logging
LOG_LEVEL=info

# Firm identity
# - stdio (Claude Desktop): set AUDREY_FIRM_ID in claude_desktop_config.json's
#   `env` block for the audrey server entry. Required in production.
# - HTTP: bearer token in Authorization header is preferred; AUDREY_FIRM_ID
#   acts as a dev fallback.
AUDREY_FIRM_ID=

# OAuth (when configured — full flow is Stage A polish)
OAUTH_ISSUER_URL=https://app.audrey.xeqtor.com
