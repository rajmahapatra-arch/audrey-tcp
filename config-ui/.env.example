# Audrey configuration UI environment variables.
# Copy to .env.local and fill in. NEVER commit real keys.

# Supabase — the shared data plane. anon key is public-safe; RLS
# enforces isolation. URL is the same project used by the MCP server.
VITE_SUPABASE_URL=https://fjshrfjahpmtlcntqfnq.supabase.co
VITE_SUPABASE_ANON_KEY=

# Optional: MCP server base URL for richer operations that need the
# server's service-role context (e.g. enqueueing extraction jobs from
# the UI when we add an HTTP endpoint for that). Direct Supabase writes
# cover the common cases; this is forward-looking.
VITE_AUDREY_MCP_BASE=https://mcp.audrey.xeqtor.com

# Where this app is served (used for OAuth redirect URLs).
# Local dev: http://localhost:3002
# Prod: https://app.audrey.xeqtor.com
VITE_APP_URL=http://localhost:3002
